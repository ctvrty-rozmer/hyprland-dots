{
    "layer": "top",
    "position": "top",
    "reload_style_on_change": true,
    "height": 6,
    "modules-left": [
        "clock",
        "hyprland/workspaces",
        "cava"
    ],
    "modules-center": [],
    "modules-right": [
        "group/expand",
        "group/networking",
        "group/hardware",
        "custom/notification"
    ],
    "hyprland/workspaces": {
        "workspace-taskbar": "false",
        "format": "{name}",
        "format-icons": {},
        "format-window-separator": "",
        "persistent-workspaces": {
            "*": [
                1,
                2,
                3,
                4,
                5
            ]
        }
    },
    "custom/notification": {
        "tooltip": false,
        "format": "",
        "on-click": "swaync-client -t -sw",
        "escape": true
    },
    "clock": {
        "format": "{:%A, %B %d | %H:%M}",
        "interval": 1,
        "tooltip-format": "<span><big>{calendar}</big></span>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "format": {
                "today": "<span color='#9E9E9E'><b><u>{}</u></b></span>",
                "months": "<span color='#F3F4F4F4'><b>{}</b></span>",
                "weekdays": "<span color='#767676'><u>{}</u></span>",
                "days": "<span color='#585858'>{}</span>",
                "weeks": "<span color='#9E9E9E'><b>├w{}</b></span>"
            }
        },
        "actions": {
            "on-click": "mode"
        }
    },
    "network": {
        "format-wifi": "",
        "format-ethernet": "",
        "format-disconnected": "",
        "tooltip-format-disconnected": "Disconnected",
        "tooltip-format-wifi": "{essid} ({signaldBm}dBm)\n{ipaddr}\nDownload: {bandwidthDownBytes}\nUpload: {bandwidthUpBytes}",
        "tooltip-format-ethernet": "{ifname} 🖧 ",
        "on-click": "kitty nmtui"
    },
    "bluetooth": {
        "format-on": "󰂯",
        "format-off": "BT-off",
        "format-disabled": "󰂲",
        "format-connected-battery": "{device_battery_percentage}% 󰂯",
        "format-alt": "{device_alias} 󰂯",
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\n{device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\n{device_address}\n{device_battery_percentage}%",
        "on-click-right": "blueman-manager"
    },
    "battery": {
        "interval": 30,
        "states": {
            "good": 95,
            "warning": 20,
            "critical": 10
        },
        "format": "{icon} {capacity}%",
        "format-charging": "{capacity}% 󰂄",
        "format-plugged": "{capacity}% 󰂄 ",
        "format-alt": "{time} {icon}",
        "format-icons": [
            "󰁻",
            "󰁼",
            "󰁾",
            "󰂀",
            "󰂂",
            "󰁹"
        ]
    },
    "custom/expand": {
        "format": "",
        "tooltip": false
    },
    "tray": {
        "icon-size": 12,
        "spacing": 6
    },
    "custom/endpoint": {
        "format": "|",
        "tooltip": false
    },
    "group/expand": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 350,
            "transition-to-left": true,
            "click-to-reveal": true
        },
        "modules": [
            "custom/expand",
            "tray",
            "custom/endpoint"
        ]
    },
    "group/hardware": {
        "orientation": "horizontal",
        "modules": [
            "pulseaudio#microphone",
            "pulseaudio",
            "battery"
        ]
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "",
        "format-icons": {
            "default": [
                "",
                "",
                "",
                ""
            ]
        }
    },
    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "",
        "format-source-muted": ""
    },
    "group/networking": {
        "orientation": "horizontal",
        "modules": [
            "network",
            "bluetooth"
        ]
    },

            "cava":{
                "framerate": 30,
                "autosens": 1,
                "sensitivity": 100,
                "bars": 8,
                "lower_cutoff_freq": 30,
                "higher_cutoff_freq": 10000,
                "hide_on_silence": true,
            }
        
    }

