include ~/.cache/wal/colors-kitty.conf
background_opacity 0.80
enable_background_blur yes
background_blur 60
allow_remote_control yes
scrollbar_width 0

# BEGIN_KITTY_FONTS
font_family      family="Hack Nerd Font"
font_size 8
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS

# KITTY CURSOR
cursor_shape beam
cursor_beam_thickness 1.9
cursor_blink_interval .5 ease-in-out
cursor_trail 10
cursor_trail_decay 0.2 0.4
cursor_trail_start_threshold 7
cursor_trail_color #964bbb



